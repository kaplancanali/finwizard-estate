# Application
APP_NAME=property-service
APP_ENV=development
LOG_LEVEL=DEBUG
DEBUG=true

# Database (host ports when using docker compose: postgres=5433, redis=6380, api=8001)
DATABASE_URL=postgresql+asyncpg://property:property@localhost:5433/property_db

# Redis
REDIS_URL=redis://localhost:6380/0
REDIS_MAX_CONNECTIONS=20

# RabbitMQ (Celery)
RABBITMQ_URL=amqp://property:property@localhost:5672/

# Object Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=property-media
S3_REGION=us-east-1

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_AUDIENCE=property-service
JWT_ISSUER=
JWKS_URL=
REQUIRE_AUTHENTICATION=false

# Security
RATE_LIMIT_PER_MINUTE=600
RATE_LIMIT_UNAUTHENTICATED_PER_MINUTE=60
PRESIGNED_URL_TTL_SECONDS=3600

# Migrations
RUN_MIGRATIONS=false
SEED_LOOKUPS=false
