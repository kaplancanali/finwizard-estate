# Application
APP_NAME=property-service
APP_ENV=development
LOG_LEVEL=DEBUG
DEBUG=true

# Database (docker compose host port: 5433)
DATABASE_URL=postgresql+asyncpg://property:property@localhost:5433/property_db

# Redis (docker compose host port: 6380)
REDIS_URL=redis://localhost:6380/0
REDIS_MAX_CONNECTIONS=20

# RabbitMQ (Celery)
RABBITMQ_URL=amqp://property:property@localhost:5672/

# Object Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=property-media
S3_REGION=us-east-1

# Auth (local HS256). Production: set JWKS_URL + JWT_ALGORITHM=RS256 from Identity API.
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_AUDIENCE=property-service
JWT_ISSUER=
JWKS_URL=
REQUIRE_AUTHENTICATION=false

# External platform APIs — populate from Identity / finward-api when available
IDENTITY_BASE_URL=
FINWARD_API_BASE_URL=
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Analysis services are NOT called by property-service (outbound forbidden).
# Frontend AI inventory reports use OPENAI_API_KEY on the Next.js app (see frontend/.env.example).
# Endeksa / Valuation / Risk are paid enterprise APIs — leave empty until contracted.
# Until then, listings come from this property-service (seed: make seed-demo).
# NEXT_PUBLIC_VALUATION_API_URL=
# NEXT_PUBLIC_RISK_API_URL=
# NEXT_PUBLIC_INVESTMENT_API_URL=
# ENDEKSA_API_BASE_URL=
# ENDEKSA_CLIENT_ID=
# ENDEKSA_CLIENT_SECRET=

# Security
RATE_LIMIT_PER_MINUTE=600
RATE_LIMIT_UNAUTHENTICATED_PER_MINUTE=60
PRESIGNED_URL_TTL_SECONDS=3600
CORS_ORIGINS=["*"]

# Migrations
RUN_MIGRATIONS=false
SEED_LOOKUPS=false
