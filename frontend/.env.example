# Must match property-service JWT_SECRET (used to mint login JWTs)
JWT_SECRET=dev-secret-change-in-production

# Next.js rewrite target → property-service API (local only; omit on Vercel to use demo catalog)
BACKEND_URL=http://localhost:8001

# Optional: override browser API base (default same-origin /api/v1)
# NEXT_PUBLIC_API_BASE_URL=/api/v1

# AI inventory analysis (server-only — never NEXT_PUBLIC_)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional legacy external analysis bases (unused when inventory AI is enabled)
# NEXT_PUBLIC_VALUATION_API_URL=
# NEXT_PUBLIC_RISK_API_URL=
# NEXT_PUBLIC_INVESTMENT_API_URL=
# NEXT_PUBLIC_FINWARD_API_URL=
